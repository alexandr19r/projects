# [vim.env] - Специфические данные редактора (VIM)

# --- ПОЛЬЗОВАТЕЛЬСКИЕ НАСТРОЙКИ ---
export USER_NAME="${USER_NAME:-$(whoami)}"
export USER_HOME=$(getent passwd "$USER_NAME" | cut -d: -f6)

# --- ДАННЫЕ ДЛЯ ШАБЛОНОВ (Metadata) ---
# Имя текущего пользователя (админа)
export AUTHOR="${USER:-admin}" # $(id -un)
# Авто-генерация даты при каждом запуске скрипта
export LAST_MODIFIED=$(date '+%Y-%m-%d %H:%M')