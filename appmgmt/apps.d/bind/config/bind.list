#file   | none                                     | /var/log/named/named.log                     | 640  | syslog:adm | none   | none | "Файл логов DNS"                                                 | none
#file   | none                                     | /var/log/named/queries.log                   | 640  | bind:adm   | none   | none | "Файл запросов DNS"                                              | none
#file   | bind//rsyslog_bind                       | /etc/rsyslog.d/named.conf                    | 644  | root:root  | none   | none | "Настройка логов BIND9 (local6)"                                 | AUTHOR|LAST_MODIFIED|RSYSLOG_DNS
#file   | bind//logrotate_bind                     | /etc/logrotate.d/named                       | 644  | root:root  | none   | none | "Ротация логов BIND9"                                            | AUTHOR|LAST_MODIFIED|RSYSLOG_DNS
