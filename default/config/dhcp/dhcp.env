# [dhcp.env] - Специфические данные сервера (DHCP)

# --- СЕТЕВЫЕ ИНТЕРФЕЙСЫ ---
# Если оставить пустым, скрипт определит интерфейс автоматически
export DHCP_INTERFACE="eth0"
export LOCAL_DOMAIN="home.local"         # Ваш локальный домен (например, corp.local)

# --- ПАРАМЕТРЫ IPv4 (Сеть 10.10.100.0/24) ---
export SERVER_IP_V4="10.10.100.1"     # IP-адрес вашего сервера
export LOCAL_SUBNET_V4="10.10.100.0/24"
export ROUTER_IP_V4="10.10.100.2"

# Вспомогательные данные для конфига DHCP (ISC DHCP или Dnsmasq)
export LOCAL_BROADCAST="10.10.100.255"
export LOCAL_NETMASK="255.255.255.0"
export DHCP_RANGE_START="10.10.100.100"
export DHCP_RANGE_END="10.10.100.200"
export GOOGLE_DNS="8.8.8.8"

# --- ПАРАМЕТРЫ СТАТИЧЕСКИХ КЛИЕНТОВ IPv4 ---
export GW_MAC="00:15:5D:00:03:04"
export GW_IP_V4="10.10.100.2"
export DEVSRV_MAC="00:15:5D:00:6A:02"
export DEVSRV_IP_V4="10.10.100.3"
export SRV1C_MAC="00:15:5D:00:6A:03"
export SRV1C_IP_V4="10.10.100.4"

# --- ПАРАМЕТРЫ IPv6 (Сеть fd00:db9:aaaa::/64) ---
export SERVER_IP_V6="fd00:db9:aaaa::1"     # IP-адрес вашего сервера
export LOCAL_SUBNET_V6="fd00:db9:aaaa::/64"
export ROUTER_IP_V6="fd00:db9:aaaa::2"
export DHCP6_RANGE_START="fd00:db9:aaaa::100"
export DHCP6_RANGE_END="fd00:db9:aaaa::200"

# --- ПАРАМЕТРЫ СТАТИЧЕСКИХ КЛИЕНТОВ IPv4 ---
export GW_DUID="00:01:00:01:2B:4C:09:F1:34:6F:24:6B:C1:95"
export GW_IP_V6="fd00:db9:aaaa::2"
export DEVSRV_DUID="00:01:00:01:2A:E1:6D:49:00:15:5D:00:6A:02"
export DEVSRV_IP_V6="fd00:db9:aaaa::3"
export SRV1C_DUID="00:01:00:01:2A:99:15:B6:00:15:5D:00:67:00"
export SRV1C_IP_V6="fd00:db9:aaaa::4"

# --- ДАННЫЕ ДЛЯ ШАБЛОНОВ (Metadata) ---
# Имя текущего пользователя (админа)
export AUTHOR="${USER:-admin}" # $(id -un)
# Авто-генерация даты при каждом запуске скрипта
export LAST_MODIFIED=$(date '+%Y-%m-%d %H:%M')

# --- СИСТЕМНЫЕ НАСТРОЙКИ ---
# Пользователь, под которым rsyslog пишет логи nftables
export RSYSLOG_DHCP="/var/log/dhcp/dhcp.log"
export DHCP_LOG_USER="syslog"
export DHCP_LOG_GROUP="adm"