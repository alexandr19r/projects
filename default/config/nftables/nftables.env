# [nftables.env] - Специфика сервера nftables
# Задаваемые переменные для шаблонов
export DHCP_INTERFACE="eth0"
export RSYSLOG_NFTABLES="/var/log/nftables/nftables.log"
# Вычисляемые переменные для шаблонов
export AUTHOR=$(id -un) #Имя текущего пользователя системы
export LAST_MODIFIED=$(date '+%Y-%m-%d') #Текущая дата изменения

# export AUTHOR="admin_devops"
# export LAST_MODIFIED="2026-01-09"